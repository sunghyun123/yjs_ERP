# .env.production.example
# VPS에서 이 파일을 복사하여 실제 값으로 채우세요:
#   cp .env.production.example .env.production
#
# Next.js는 NODE_ENV=production일 때 .env.production을 자동으로 로드합니다.
# 이 파일(.env.production.example)은 git에 포함됩니다.
# 실제 키가 담긴 .env.production은 절대 git에 커밋하지 마세요.

# ── Supabase ──────────────────────────────────────────────
# Supabase 프로젝트 대시보드 → Settings → API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service Role Key: RLS 우회 (마이그레이션 스크립트 전용)
# 절대 NEXT_PUBLIC_ 접두사 붙이지 말 것 — 브라우저에 노출됨
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Next.js ───────────────────────────────────────────────
# PM2 ecosystem.config.js의 PORT와 반드시 일치시킬 것
PORT=3001
